{
  "name": "six-cities",
  "version": "4.0.0",
  "description": "Проект «Шесть городов» от HTML Academy",
  "keywords": [
    "rest",
    "api",
    "node.js"
  ],
  "main": "main.js",
  "scripts": {
    "start": "npm run build && node ./dist/main.cli.js",
    "build": "npm run clean && npm run compile",
    "lint": "eslint src/ --ext .ts",
    "compile": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "ts": "ts-node",
    "cli": "node --loader ts-node/esm src/main.cli.ts",
    "mock:server": "json-server --watch mocks/mock-server-data.json --port 3000",
    "logs": "node --loader ts-node/esm src/main.ts | pino-pretty"
  },
  "devDependencies": {
    "@types/convict": "^6.1.6",
    "@types/convict-format-with-validator": "^6.0.6",
    "@types/node": "24.11.1",
    "@typescript-eslint/eslint-plugin": "5.46.0",
    "@typescript-eslint/parser": "5.46.0",
    "eslint": "8.39.0",
    "eslint-config-htmlacademy": "9.1.1",
    "json-server": "^0.17.4",
    "pino-pretty": "^10.3.1",
    "rimraf": "3.0.2",
    "ts-node": "10.9.1",
    "typescript": "4.9.5"
  },
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8"
  },
  "dependencies": {
    "@typegoose/typegoose": "^13.2.1",
    "chalk": "^5.6.2",
    "convict": "^6.2.5",
    "convict-format-with-validator": "^6.2.0",
    "dotenv": "^17.4.2",
    "got": "^14.6.6",
    "inversify": "^8.1.0",
    "mongoose": "~9.2.2",
    "pino": "^8.21.0",
    "reflect-metadata": "^0.2.2"
  }
}
